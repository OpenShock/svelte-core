{
	"name": "@openshock/svelte-core",
	"version": "0.2.1",
	"description": "Shared OpenShock Svelte/SvelteKit core: shadcn-svelte component baseline, design-system theme, and common utilities used by both the cloud frontend and the firmware captive portal.",
	"license": "AGPL-3.0-or-later",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/OpenShock/svelte-core.git"
	},
	"packageManager": "pnpm@11.9.0",
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && svelte-package && publint",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"update-shadcn": "node scripts/update-shadcn.js",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"changeset": "changeset",
		"release": "changeset publish"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*",
		"!dist/**/README.md"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./theme.css": "./dist/theme.css",
		"./components": {
			"types": "./dist/components/index.d.ts",
			"svelte": "./dist/components/index.js",
			"default": "./dist/components/index.js"
		},
		"./components/input": {
			"types": "./dist/components/input/index.d.ts",
			"svelte": "./dist/components/input/index.js",
			"default": "./dist/components/input/index.js"
		},
		"./components/svg": {
			"types": "./dist/components/svg/index.d.ts",
			"svelte": "./dist/components/svg/index.js",
			"default": "./dist/components/svg/index.js"
		},
		"./components/datetime-picker": {
			"types": "./dist/components/datetime-picker/index.d.ts",
			"svelte": "./dist/components/datetime-picker/index.js",
			"default": "./dist/components/datetime-picker/index.js"
		},
		"./components/dialog-manager": {
			"types": "./dist/components/dialog-manager/index.d.ts",
			"svelte": "./dist/components/dialog-manager/index.js",
			"default": "./dist/components/dialog-manager/index.js"
		},
		"./ui/*": {
			"types": "./dist/components/ui/*/index.d.ts",
			"svelte": "./dist/components/ui/*/index.js"
		},
		"./components/*": {
			"types": "./dist/components/*.d.ts",
			"svelte": "./dist/components/*",
			"default": "./dist/components/*"
		},
		"./metadata": {
			"types": "./dist/components/metadata/index.d.ts",
			"svelte": "./dist/components/metadata/index.js"
		},
		"./stepper": {
			"types": "./dist/components/stepper/index.d.ts",
			"svelte": "./dist/components/stepper/index.js"
		},
		"./multi-select-combobox": {
			"types": "./dist/components/multi-select-combobox/multi-select-combobox.svelte.d.ts",
			"svelte": "./dist/components/multi-select-combobox/multi-select-combobox.svelte"
		},
		"./utils": {
			"types": "./dist/utils/index.d.ts",
			"default": "./dist/utils/index.js"
		},
		"./utils/*": {
			"types": "./dist/utils/*.d.ts",
			"svelte": "./dist/utils/*.js",
			"default": "./dist/utils/*.js"
		},
		"./types/*": {
			"types": "./dist/types/*.d.ts",
			"default": "./dist/types/*.js"
		},
		"./inputvalidation/*": {
			"types": "./dist/inputvalidation/*.d.ts",
			"default": "./dist/inputvalidation/*.js"
		},
		"./api/*": {
			"types": "./dist/api/*.d.ts",
			"default": "./dist/api/*.js"
		},
		"./hooks/is-mobile.svelte": {
			"types": "./dist/hooks/is-mobile.svelte.d.ts",
			"svelte": "./dist/hooks/is-mobile.svelte.js",
			"default": "./dist/hooks/is-mobile.svelte.js"
		},
		"./typeguards": {
			"types": "./dist/typeguards/index.d.ts",
			"svelte": "./dist/typeguards/index.js"
		},
		"./state/*": {
			"types": "./dist/state/*.d.ts",
			"svelte": "./dist/state/*.js",
			"default": "./dist/state/*.js"
		},
		"./package.json": "./package.json"
	},
	"peerDependencies": {
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.21.0",
		"@tanstack/table-core": "^8.21.3",
		"bits-ui": "2.18.1",
		"clsx": "^2.1.1",
		"formsnap": "^2.0.1",
		"svelte": "^5.56.1",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"temporal-polyfill": "^1.0.1",
		"vaul-svelte": "1.0.0-next.7"
	},
	"peerDependenciesMeta": {
		"@internationalized/date": {
			"optional": true
		},
		"@tanstack/table-core": {
			"optional": true
		},
		"formsnap": {
			"optional": true
		},
		"sveltekit-superforms": {
			"optional": true
		},
		"temporal-polyfill": {
			"optional": true
		},
		"vaul-svelte": {
			"optional": true
		}
	},
	"devDependencies": {
		"@changesets/cli": "^2.27.0",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.21.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.66.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@tanstack/table-core": "^8.21.3",
		"bits-ui": "2.18.1",
		"clsx": "^2.1.1",
		"formsnap": "^2.0.1",
		"prettier": "^3.8.4",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"publint": "^0.3.21",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"svelte-sonner": "^1.1.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.1",
		"temporal-polyfill": "^1.0.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"keywords": [
		"svelte",
		"sveltekit",
		"shadcn-svelte",
		"openshock",
		"component-library"
	]
}
